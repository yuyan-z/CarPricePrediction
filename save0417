# 用法示例
# ======================
if __name__ == "__main__":
    # 示例：读取你的数据
    # df = pd.read_csv("stocks.csv")

    # 这里构造一个假的例子
    rng = np.random.default_rng(42)
    n_stocks = 200
    time_steps = 60

    base = rng.normal(size=(n_stocks, time_steps)).cumsum(axis=1)
    target = rng.random(n_stocks) > 0.5

    # 给 target=True 注入几种“形状”
    for i in range(n_stocks):
        if target[i]:
            pattern_type = i % 3
            if pattern_type == 0:
                base[i] += np.linspace(0, 8, time_steps)          # 缓慢上升
            elif pattern_type == 1:
                half = time_steps // 2
                base[i, :half] -= np.linspace(0, 5, half)         # V型反转前半段
                base[i, half:] += np.linspace(0, 8, time_steps-half)
            else:
                base[i] += np.sin(np.linspace(0, 3*np.pi, time_steps)) * 2 + np.linspace(0, 4, time_steps)

    columns = [f"t{i}" for i in range(time_steps)]
    df = pd.DataFrame(base, columns=columns)
    df["stock_id"] = [f"S{i:04d}" for i in range(n_stocks)]
    df["target"] = target

    # 运行 K-Shape
    clustered_true_df, ks, X_scaled = run_kshape_on_true_group(
        df=df,
        target_col="target",
        id_col="stock_id",
        n_clusters=3,
        random_state=42,
    )

    print(clustered_true_df.head())
    print("\nCluster counts:")
    print(clustered_true_df["cluster"].value_counts().sort_index())

    # 画图
    plot_kshape_clusters(ks, X_scaled)

    # 合并回原始表
    df_with_cluster = attach_cluster_to_original_df(df, clustered_true_df, id_col="stock_id")
    print(df_with_cluster.head())
